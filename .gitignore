# Helix AI Studio .gitignore

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
!frontend/dist/
build/
*.egg

# PyInstaller
*.exe
*.spec
*.spec.bak

# Environment
.env
*.env
.venv/
env/
venv/

# Config (contains API keys — exclude all except example files)
config/*
!config/*.example.json
!config/model_capabilities.json
data/web_execution_lock.json

# Runtime data
data/
logs/
*.db
*.sqlite
*.sqlite3

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
Desktop.ini
*.lnk

# Node (for Claude Code CLI)
node_modules/

# Temporary
*.tmp
*.bak
*.orig

nul

# Development/debug artifacts
debug_overnight_log.md
debug_out*.txt
patch_z*.py
patch_z*_i18n.py
restore_ja.py
ja_backup.json
helix_source_bundle.txt

# Pipeline artifacts
screenshots/
/demo.gif
/demo.mp4

# Personal/development files
.claude/
修正/
成果品/
BIBLE/
GitHub/
snippets/

# Demo captures (work-in-progress screenshots/GIFs)
demo_captures/
exec_check*.png
screenshot_*.png
webui_cloudai_jp_done.png
webui_current_state.png
webui_localai_*.png
webui_state*.png

# Docker Sandbox
docker/sandbox/tmp/
.helix-backup-*/
data/sandbox_snapshots/
.backup/
backup.bat
scripts/backup_tool.py

# Playwright MCP
.playwright-mcp/

# Demo video logs and MP4 recordings (too large for git)
docs/demo/**/*.log
docs/demo/**/*.mp4

# GitHub README check screenshots
github_readme_*.png

# Utility scripts (note/reddit/chrome/demo automation — not part of the app)
scripts/note_*.py
scripts/reddit_*.py
scripts/reddit_*.txt
scripts/chrome_*.ps1
scripts/check_*.ps1
scripts/copy_chrome_profile.ps1
scripts/launch_chrome_cdp.ps1
scripts/record_demo_gif.py
scripts/record_demo_videos.py
scripts/record_webui_videos.py
scripts/capture_frames.py
scripts/demo_recorder.py
scripts/generate_demo_gif.py
scripts/take_screenshots.py
scripts/post_to_note.py

